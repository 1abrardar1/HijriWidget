<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <corners android:radius="22dp" />

    <gradient
        android:angle="270"
        android:startColor="#131318"
        android:centerColor="#1C1B22"
        android:endColor="#2B2930" />

    <stroke
        android:width="1dp"
        android:color="#33938F99" />

    <padding
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp" />
</shape>
