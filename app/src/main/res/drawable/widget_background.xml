<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <gradient
                android:angle="270"
                android:startColor="#131318"
                android:centerColor="#1C1B22"
                android:endColor="#2B2930" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="110dp"
                android:centerX="0.5"
                android:centerY="0.0"
                android:startColor="#26A89AFF"
                android:endColor="#00000000" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <stroke
                android:width="1dp"
                android:color="#33938F99" />
        </shape>
    </item>

</layer-list>
