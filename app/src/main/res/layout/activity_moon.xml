<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050d1a">

    <com.hijri.widget.MoonArcView
        android:id="@+id/moon_arc_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/top_info_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="40dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:background="@drawable/moon_info_bg">

        <TextView
            android:id="@+id/tv_hijri_full"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12 Shawwal 1447 AH"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2" />

        <TextView
            android:id="@+id/tv_hijri_ar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="شَوَّال"
            android:textColor="#CCFFFFFF"
            android:textSize="18sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tv_greg_full"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Tue, 31 Mar 2026"
            android:textColor="#99FFFFFF"
            android:textSize="13sp"
            android:gravity="center" />

    </LinearLayout>

    <TextView
        android:id="@+id/btn_close"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:gravity="center"
        android:text="✕"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:background="@drawable/close_button_bg" />

</FrameLayout>
