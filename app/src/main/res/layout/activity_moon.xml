<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <com.hijri.widget.MoonArcView
        android:id="@+id/moon_arc_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/top_info_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="52dp"
        android:layout_marginLeft="28dp"
        android:layout_marginRight="28dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingLeft="24dp"
        android:paddingTop="18dp"
        android:paddingRight="24dp"
        android:paddingBottom="18dp"
        android:background="@drawable/moon_info_bg">

        <TextView
            android:id="@+id/tv_hijri_full"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 Muharram 1446 AH"
            android:textColor="@color/md_theme_onSurface"
            android:textSize="24sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2"
            android:shadowColor="#55000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3" />

        <TextView
            android:id="@+id/tv_greg_full"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Mon, 1 Jan 2025"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:textSize="13sp"
            android:fontFamily="sans-serif"
            android:gravity="center" />
    </LinearLayout>

    <TextView
        android:id="@+id/btn_close"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:gravity="center"
        android:text="✕"
        android:textColor="@color/md_theme_onSurface"
        android:textSize="20sp"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/close_button_bg" />

</FrameLayout>
