<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/widget_background">

    <TextView
        android:id="@+id/tv_source_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Waxing Crescent"
        android:textSize="9sp"
        android:textColor="#AAB4C5E4"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.08"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tv_hijri_day"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1"
        android:textSize="52sp"
        android:textColor="#FFFFFFFF"
        android:fontFamily="sans-serif-thin"
        android:letterSpacing="-0.03" />

    <TextView
        android:id="@+id/tv_hijri_month_ar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Muharram"
        android:textSize="13sp"
        android:textColor="#88B4C5E4"
        android:layout_marginTop="2dp"
        android:fontFamily="sans-serif" />

    <TextView
        android:id="@+id/tv_hijri_month"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Muharram"
        android:textSize="14sp"
        android:textColor="#DDFFFFFF"
        android:layout_marginTop="2dp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.05" />

    <TextView
        android:id="@+id/tv_hijri_year"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1446 AH"
        android:textSize="12sp"
        android:textColor="#88FFFFFF"
        android:layout_marginTop="2dp"
        android:fontFamily="sans-serif" />

    <View
        android:layout_width="28dp"
        android:layout_height="1dp"
        android:background="#33CAC4D0"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/tv_gregorian_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mon, 1 Jan 2025"
        android:textSize="11sp"
        android:textColor="#66FFFFFF"
        android:fontFamily="sans-serif" />

    <TextView
        android:id="@+id/loading_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Updating..."
        android:textSize="10sp"
        android:textColor="#66FFFFFF"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        android:fontFamily="sans-serif" />

</LinearLayout>
