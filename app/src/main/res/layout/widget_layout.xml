<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="14dp"
    android:background="@drawable/widget_background">

    <TextView
        android:id="@+id/tv_source_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Verified"
        android:textStyle="bold"
        android:textSize="10sp"
        android:textColor="#FFF8D6"
        android:background="#335C4B"
        android:paddingLeft="8dp"
        android:paddingTop="3dp"
        android:paddingRight="8dp"
        android:paddingBottom="3dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_hijri_day"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1"
        android:textStyle="bold"
        android:textSize="40sp"
        android:textColor="#FFFFFF" />

    <TextView
        android:id="@+id/tv_hijri_month_ar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="مُحَرَّم"
        android:textSize="13sp"
        android:textColor="#EADFB8"
        android:layout_marginTop="2dp" />

    <TextView
        android:id="@+id/tv_hijri_month"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Muharram"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:layout_marginTop="2dp" />

    <TextView
        android:id="@+id/tv_hijri_year"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1446 AH"
        android:textSize="12sp"
        android:textColor="#D9E6F2"
        android:layout_marginTop="2dp" />

    <TextView
        android:id="@+id/tv_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:text=""
        android:background="#33FFFFFF"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/tv_gregorian_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mon, 1 Jan 2025"
        android:textSize="11sp"
        android:textColor="#D9E6F2" />

    <TextView
        android:id="@+id/tv_moon_phase_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WAXING CRESCENT"
        android:textStyle="bold"
        android:textSize="11sp"
        android:textColor="#FFF4C2"
        android:layout_marginTop="6dp" />

    <TextView
        android:id="@+id/loading_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Updating..."
        android:textSize="10sp"
        android:textColor="#BFD3E6"
        android:layout_marginTop="8dp"
        android:visibility="gone" />

</LinearLayout>
