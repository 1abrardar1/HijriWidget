<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="14dp"
    android:background="@drawable/widget_background">

    <TextView
        android:id="@+id/tv_source_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Verified"
        android:textStyle="bold"
        android:textSize="10sp"
        android:textColor="@color/md_theme_onSecondaryContainer"
        android:background="#664A4458"
        android:paddingLeft="8dp"
        android:paddingTop="3dp"
        android:paddingRight="8dp"
        android:paddingBottom="3dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:id="@+id/tv_hijri_day"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1"
        android:textStyle="bold"
        android:textSize="40sp"
        android:textColor="@color/md_theme_onSurface"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:id="@+id/tv_hijri_month_ar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="مُحَرَّم"
        android:textSize="13sp"
        android:textColor="@color/md_theme_tertiary"
        android:layout_marginTop="2dp"
        android:fontFamily="sans-serif" />

    <TextView
        android:id="@+id/tv_hijri_month"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Muharram"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="@color/md_theme_onSurface"
        android:layout_marginTop="2dp"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:id="@+id/tv_hijri_year"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1446 AH"
        android:textSize="12sp"
        android:textColor="@color/md_theme_onSurfaceVariant"
        android:layout_marginTop="2dp"
        android:fontFamily="sans-serif" />

    <TextView
        android:id="@+id/tv_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:text=""
        android:background="#33CAC4D0"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/tv_gregorian_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mon, 1 Jan 2025"
        android:textSize="11sp"
        android:textColor="@color/md_theme_onSurfaceVariant"
        android:fontFamily="sans-serif" />

    <TextView
        android:id="@+id/tv_moon_phase_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WAXING GIBBOUS"
        android:textStyle="bold"
        android:textSize="11sp"
        android:textColor="@color/md_theme_primary"
        android:layout_marginTop="6dp"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:id="@+id/loading_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Updating..."
        android:textSize="10sp"
        android:textColor="@color/md_theme_onSurfaceVariant"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        android:fontFamily="sans-serif" />

</LinearLayout>
